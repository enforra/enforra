{
  "name": "@enforra/cli",
  "version": "0.1.2",
  "description": "Command line tools for local Enforra setup, policy testing, and audit verification.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "enforra": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap",
    "prepack": "pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@enforra/local-audit": "^0.2.1",
    "@enforra/policy-simulator": "^0.1.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.22.4"
  }
}
