{
  "name": "@enforra/policy-simulator",
  "version": "0.1.0",
  "description": "Local policy simulation and test runner for Enforra.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap",
    "simulate": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@enforra/policy-core": "workspace:*",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.20.6"
  }
}
