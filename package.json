{
  "name": "enforra",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first runtime policy enforcement for AI agent tool calls.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm format:check && pnpm build && pnpm test && pnpm lint",
    "verify:demos": "pnpm demo:observe && pnpm demo:mcp-guard && pnpm demo:mcp-coding && pnpm demo:mcp-github && pnpm demo:mcp-governance",
    "verify:oss": "pnpm verify && pnpm verify:demos",
    "demo:support-refund": "pnpm --filter @enforra/example-support-refund-agent build && pnpm --filter @enforra/example-support-refund-agent start",
    "demo:openai-style": "pnpm --filter @enforra/example-openai-style-tool-wrapper build && pnpm --filter @enforra/example-openai-style-tool-wrapper start",
    "demo:mcp-style": "pnpm --filter @enforra/example-mcp-style-tool-policy build && pnpm --filter @enforra/example-mcp-style-tool-policy start",
    "demo:approval-evidence": "pnpm --filter @enforra/example-approval-evidence-demo build && pnpm --filter @enforra/example-approval-evidence-demo start",
    "demo:audit-integrity": "pnpm --filter @enforra/example-audit-integrity-demo build && pnpm --filter @enforra/example-audit-integrity-demo start",
    "demo:mcp-guard": "pnpm --filter @enforra/example-mcp-tool-guard-demo build && pnpm --filter @enforra/example-mcp-tool-guard-demo start",
    "demo:mcp-coding": "pnpm --filter @enforra/example-mcp-coding-agent build && pnpm --filter @enforra/example-mcp-coding-agent start",
    "demo:mcp-github": "pnpm --filter @enforra/example-mcp-github-agent build && pnpm --filter @enforra/example-mcp-github-agent start",
    "demo:mcp-governance": "pnpm --filter @enforra/example-mcp-server-governance build && pnpm --filter @enforra/example-mcp-server-governance start",
    "demo:observe": "pnpm --filter @enforra/example-support-refund-agent build && pnpm --filter @enforra/example-support-refund-agent start:observe",
    "demo:db-unsafe": "pnpm --filter @enforra/example-db-delete-video-demo build && node examples/demos/db-delete-video/dist/agent_db.js",
    "demo:db-enforra": "pnpm --filter @enforra/example-db-delete-video-demo build && node examples/demos/db-delete-video/dist/agent_db_enforra.js",
    "demo:db-unsafe:run": "node examples/demos/db-delete-video/dist/agent_db.js",
    "demo:db-enforra:run": "node examples/demos/db-delete-video/dist/agent_db_enforra.js",
    "demo:all": "pnpm demo:support-refund && pnpm demo:openai-style && pnpm demo:mcp-style && pnpm demo:approval-evidence && pnpm demo:audit-integrity && pnpm demo:mcp-guard && pnpm demo:mcp-coding && pnpm demo:mcp-github && pnpm demo:mcp-governance && pnpm demo:observe",
    "benchmark:policy": "pnpm --filter @enforra/example-benchmark-policy-eval build && pnpm --filter @enforra/example-benchmark-policy-eval start",
    "benchmark:all": "pnpm benchmark:policy",
    "bench": "pnpm benchmark:all",
    "policy:test:support-refund": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/support-agent.yaml --cases examples/quickstart/support-refund-node/policy-cases.yaml",
    "policy:test:openai-style": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/openai-style-agent.yaml --cases examples/demos/openai-style-tool-wrapper/policy-cases.yaml",
    "policy:test:mcp-style": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/mcp-tools.yaml --cases examples/mcp/mcp-style-policy/policy-cases.yaml",
    "policy:test:approval-evidence": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/approval-evidence.yaml --cases examples/audit/approval-evidence/policy-cases.yaml",
    "policy:test:all": "pnpm policy:test:support-refund && pnpm policy:test:openai-style && pnpm policy:test:mcp-style && pnpm policy:test:approval-evidence"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.25",
    "eslint": "^10.4.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  }
}
