{
  "name": "enforra",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first runtime policy enforcement for AI agent tool calls.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "demo:support-refund": "pnpm --filter @enforra/example-support-refund-agent build && pnpm --filter @enforra/example-support-refund-agent start",
    "demo:openai-style": "pnpm --filter @enforra/example-openai-style-tool-wrapper build && pnpm --filter @enforra/example-openai-style-tool-wrapper start",
    "demo:mcp-style": "pnpm --filter @enforra/example-mcp-style-tool-policy build && pnpm --filter @enforra/example-mcp-style-tool-policy start",
    "demo:approval-evidence": "pnpm --filter @enforra/example-approval-evidence-demo build && pnpm --filter @enforra/example-approval-evidence-demo start",
    "demo:audit-integrity": "pnpm --filter @enforra/example-audit-integrity-demo build && pnpm --filter @enforra/example-audit-integrity-demo start",
    "demo:db-unsafe": "pnpm --filter @enforra/example-db-delete-video-demo build && node examples/db-delete-video-demo/dist/agent_db.js",
    "demo:db-enforra": "pnpm --filter @enforra/example-db-delete-video-demo build && node examples/db-delete-video-demo/dist/agent_db_enforra.js",
    "demo:db-unsafe:run": "node examples/db-delete-video-demo/dist/agent_db.js",
    "demo:db-enforra:run": "node examples/db-delete-video-demo/dist/agent_db_enforra.js",
    "demo:all": "pnpm demo:support-refund && pnpm demo:openai-style && pnpm demo:mcp-style && pnpm demo:approval-evidence && pnpm demo:audit-integrity",
    "benchmark:policy": "pnpm --filter @enforra/example-benchmark-policy-eval build && pnpm --filter @enforra/example-benchmark-policy-eval start",
    "benchmark:all": "pnpm benchmark:policy",
    "bench": "pnpm benchmark:all",
    "policy:test:support-refund": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/support-agent.yaml --cases examples/support-refund-agent/policy-cases.yaml",
    "policy:test:openai-style": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/openai-style-agent.yaml --cases examples/openai-style-tool-wrapper/policy-cases.yaml",
    "policy:test:mcp-style": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/mcp-tools.yaml --cases examples/mcp-style-tool-policy/policy-cases.yaml",
    "policy:test:approval-evidence": "pnpm --filter @enforra/policy-simulator build && node packages/policy-simulator/dist/cli.js --policy policies/starter/approval-evidence.yaml --cases examples/approval-evidence-demo/policy-cases.yaml",
    "policy:test:all": "pnpm policy:test:support-refund && pnpm policy:test:openai-style && pnpm policy:test:mcp-style && pnpm policy:test:approval-evidence"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.19.25",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  }
}
